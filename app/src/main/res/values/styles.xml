<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="TextStyle_geologic_regular">
        <item name="android:fontFamily">@font/geologica_regular1</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/_24sp</item>
        <item name="android:lineHeight">@dimen/_26dp</item>
        <item name="android:textColor">@color/black</item>

    </style>


    <style name="RegisterStyle">
        <item name="android:textAppearance">@style/TextStyle_geologic_regular</item>



    </style>


    <style name="TextStyle_NotoSans_Regular" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/noto_sans_hk</item>
        <item name="android:textSize">@dimen/_14sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/black</item>


    </style>

    <style name="InputEditTextStyle">
        <item name="android:textAppearance">@style/TextStyle_NotoSans_Regular</item>
        <item name="android:paddingTop">@dimen/_4dp</item>
        <item name="android:paddingBottom">@dimen/_4dp</item>

    </style>

    <style name="InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearance">@style/ShapeAppearance.Medium.Rounded18</item>
        <item name="android:layout_marginVertical">@dimen/_4dp</item>
        <item name="boxStrokeWidth">@dimen/_1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintEnabled">false</item>

    </style>


    <style name="CustomButtonMaterial" parent="Widget.Material3.Button.OutlinedButton">

        <item name="strokeWidth">@dimen/_1dp</item>
        <item name="android:insetTop">@dimen/_0dp</item>
        <item name="android:insetBottom">@dimen/_0dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="strokeColor">@color/black</item>
        <item name="android:textAppearance">@style/TextStyle_NotoSans_Regular</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Large.Rounded28</item>


    </style>

    <style name="CustomButtonSave" parent="CustomButtonMaterial">

        <item name="strokeColor">@color/button_save_stroke_selector</item>
        <item name="android:backgroundTint">@color/button_save_selector</item>


    </style>


    <style name="ShapeAppearance.Small.Rounded8" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">@dimen/_8dp</item>
    </style>

    <style name="ShapeAppearance.Medium.Rounded18" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">@dimen/_18dp</item>
    </style>

    <style name="ShapeAppearance.Large.Rounded28" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">@dimen/_28dp</item>
    </style>


</resources>