<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MyTheme" parent="Theme.Material3.Light.NoActionBar">

        <item name="colorPrimary">@color/purple_700</item>
        <item name="colorOnPrimary">@color/Focus_Grey</item>

        <item name="colorSecondary">@color/black</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <item name="colorSurfaceVariant">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/black</item>

        <item name="colorError">@color/purple_200</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/Dark_Fon</item>

        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>


        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Small.Rounded8</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Medium.Rounded18</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Large.Rounded28</item>
    </style>


</resources>